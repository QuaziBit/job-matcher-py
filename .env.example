# Copy to .env and fill in your values

# Required for Anthropic provider
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Ollama settings (defaults shown)
OLLAMA_BASE_URL=http://localhost:11434

# Options: llama3.1:8b, llama3.3:70b, deepseek-r1:32b, gemma3:27b, mistral:7b, phi3.5:3.8b
OLLAMA_MODEL=llama3.1:8b

# Timeout in seconds — increase for large models (27B, 70B can take 2-5 min)
# 120 = fast models (8B), 300 = medium (13B-32B), 600 = large (70B+)
OLLAMA_TIMEOUT=600

# Analysis depth — controls prompt size, snippet length, and token limits
# fast     = ~30s  · short snippets (40 chars) · no suggestions · num_predict=800
# standard = ~90s  · medium snippets (70 chars) · suggestions on · num_predict=1800
# detailed = ~4min · full snippets (100 chars)  · all skills     · num_predict=4096
ANALYSIS_MODE=standard

# Optional: custom DB path (defaults to ./job_matcher.db)
# DB_PATH=/path/to/job_matcher.db

# ── Server settings ────────────────────────────────────────────────────────────
#
# APP_PORT: port the web app listens on (default: 8000)
# Valid range: 1024–65535. Common choices:
#   8000  — default, standard for local dev
#   8080  — common alternative if 8000 is taken
#   8888  — avoids conflict with Jupyter if you run it locally
#   5000  — Flask-style convention
#   3000  — Node/React convention, works fine here too
#   9000  — useful if running multiple local services
#
# APP_HOST: interface to bind to (default: 127.0.0.1 = localhost only)
#   127.0.0.1  — accessible only from this machine (safest for local use)
#   0.0.0.0    — accessible from other devices on your network (LAN sharing)
#
APP_PORT=8000
APP_HOST=127.0.0.1

# ── Debugging ──────────────────────────────────────────────────────────────────
#
# SHOW_MORE_LOGS: set to true to see raw chunk responses in the terminal.
# Useful for debugging model output when chunks fail to parse.
# Bumps chunk body logging from DEBUG to INFO level — no code changes needed.
#   false (default) — only shows chunk sizes and token counts
#   true            — also shows first 800 chars of each raw chunk response
#
# SHOW_MORE_LOGS=true
